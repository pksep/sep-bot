# Сеп-бот — пример env для e2e. Скопировать в sep-bot/env/.development.env
# Запуск: cross-env NODE_ENV=development nest start (envFilePath = env/.development.env)

PORT=3001
ALLOWED_ORIGIN=*

# Своя БД Сеп-бота (таблицы bots, updates). Та же Postgres-инстанция, отдельная БД.
DATABASE_URL=postgres://sep:sep@localhost:5433/sep_bot
CONNECT_TIMEOUT=120000

PRIVATE_KEY=dev-private-key
REDIS_URL=redis://localhost:6379
# JWT владельца ботов (для BotsController). Можно держать общим с chat_server.
JWT_SECRET=dev-jwt-secret

# 32 байта в hex (AES-256-GCM для шифрования api-токенов ботов)
BOT_TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Тот же брокер, что и у chat_server
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Файлы Сеп-бот сам в MinIO НЕ пишет (presigned выдаёт chat_server по RPC) — отключаем s3.
MINIO_DISABLED=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=sep-chat
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=http://localhost:9000
MINIO_PATH_STYLE=true
