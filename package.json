{
  "name": "sep-bot",
  "version": "0.1.0",
  "description": "Сеп-бот — шлюз ботов для sep-chat (Telegram-style Bot API ← → RabbitMQ ← → chat_server)",
  "author": "Perov David",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "init": "cross-env NODE_ENV=development INIT_SEP=true nest start --debug",
    "init:docker": "cross-env NODE_ENV=production INIT_SEP=true bun run start --debug",
    "init:docker:cluster": "cross-env NODE_CLUSTER=true pm2-runtime start bun --name \"sep-bot-cluster\" -- run init:docker -i max --no-daemon",
    "build": "cross-env NODE_ENV=production nest build",
    "actual:dist": "bun run build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "cross-env NODE_ENV=production nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test": "cross-env NODE_ENV=test jest --config ./jest.config.js --no-cache --verbose",
    "test:unit": "cross-env NODE_ENV=test jest --config ./jest.spec.config.js --verbose",
    "test:e2e": "cross-env NODE_ENV=test jest --config ./jest.e2e.config.js ",
    "migrate:up": "cross-env NODE_ENV=production ts-node -r tsconfig-paths/register ./src/scripts/migrations/umzug.ts --to=up",
    "migrate:down": "cross-env NODE_ENV=production ts-node -r tsconfig-paths/register ./src/scripts/migrations/umzug.ts --to=down",
    "migrate:status": "cross-env NODE_ENV=production ts-node -r tsconfig-paths/register ./src/scripts/migrations/umzug.ts --to=status",
    "prettier": "prettier -w src/**/*.ts -w src/**/*.json"
  },
  "dependencies": {
    "@bull-board/api": "^6.2.1",
    "@bull-board/express": "^6.2.1",
    "@bull-board/nestjs": "^6.2.1",
    "@golevelup/nestjs-rabbitmq": "^9.0.0",
    "@nestjs/bullmq": "^10.2.1",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.2.7",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.2.7",
    "@nestjs/devtools-integration": "^0.1.5",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/jwt": "^10.1.1",
    "@nestjs/platform-express": "^10.2.7",
    "@nestjs/sequelize": "^10.0.0",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/swagger": "^7.1.14",
    "@nestjs/terminus": "^10",
    "@pksep/contracts": "^1.0.2",
    "@pksep/zod-shared": "0.0.507",
    "@types/bun": "^1.2.10",
    "amqplib": "^1.0.2",
    "ansi-colors": "^4.1.3",
    "axios": "^1.14.0",
    "bullmq": "^5.20.0",
    "bun": "^1.1.29",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "content-disposition": "^0.5.4",
    "cookie-parser": "^1.4.7",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "glob": "13.0.6",
    "mime": "^4.1.0",
    "minio": "8.0.6",
    "nestjs-pino": "^4.0.0",
    "pg": "^8.11.5",
    "pino": "^8.19.0",
    "pm2": "^5.3.1",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "swagger-ui-express": "^5.0.0",
    "umzug": "^3.7.0",
    "uuid": "^9.0.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.1.25",
    "@nestjs/cli": "^10.2.0",
    "@nestjs/schematics": "^10.0.2",
    "@nestjs/testing": "^10.3.9",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.6",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.8.9",
    "@types/supertest": "^2.0.15",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "jest-jasmine2": "^29.7.0",
    "lefthook": "^1.8.2",
    "pino-pretty": "^10.3.1",
    "prettier": "^3.0.3",
    "semantic-release": "^25.0.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.4",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "parserOpts": {
            "headerPattern": "^(?:#[A-Za-z0-9-]+[\\s:]+)?(\\w+)(?:\\((.*)\\))?!?:\\s+(.*)$",
            "headerCorrespondence": [
              "type",
              "scope",
              "subject"
            ]
          },
          "releaseRules": [
            {
              "type": "feat",
              "release": "minor"
            },
            {
              "type": "fix",
              "release": "patch"
            },
            {
              "type": "recode",
              "release": "patch"
            },
            {
              "type": "perf",
              "release": "patch"
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  }
}
