# Server
PORT=5000
APPLICATION_TYPE=development
ALLOWED_ORIGIN=*

# Database
DATABASE_URL=postgres://admin:password@localhost:5432/chatbot
CONNECT_TIMEOUT=120000

# Auth
PRIVATE_KEY=your-jwt-secret-key-change-in-production
ADMIN_PASSWORD=admin123

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
MINIO_BUCKET_NAME=chatbot-files
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=http://localhost:9002
MINIO_PATH_STYLE=true
MINIO_LOCAL_BASE_URL=http://localhost:9002

# Bot API
BOT_TOKEN_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-change-in-production

# Webhook
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5000

# Logging
PINO_LOG_LEVEL=debug